# Ember Environment Variables Example
# Copy this file to .env and fill in your values
# DO NOT commit .env to version control!
#
# Ember supports 9+ LLM providers - configure the ones you want to use!

# =============================================================================
# OpenAI Configuration (GPT-4o, GPT-4o-mini, o1, o3-mini)
# Get your key at: https://platform.openai.com/api-keys
# =============================================================================
OPENAI_API_KEY=sk-your-key-here
# Optional: Custom base URL for Azure or compatible APIs
# OPENAI_BASE_URL=https://api.openai.com/v1

# =============================================================================
# Anthropic Configuration (Claude 3.5 Sonnet, Haiku, Opus)
# Get your key at: https://console.anthropic.com/
# =============================================================================
ANTHROPIC_API_KEY=sk-ant-your-key-here

# =============================================================================
# Google Gemini Configuration (Gemini 2.0, 1.5 Pro/Flash - up to 2M context!)
# Get your key at: https://aistudio.google.com/apikey
# =============================================================================
GOOGLE_API_KEY=your-google-api-key-here
# Or use the Gemini-specific variable:
# GEMINI_API_KEY=your-gemini-api-key-here

# =============================================================================
# DeepSeek Configuration (V3, R1 Reasoner - extremely cost-effective!)
# Get your key at: https://platform.deepseek.com/
# =============================================================================
DEEPSEEK_API_KEY=sk-your-deepseek-key-here

# =============================================================================
# Mistral Configuration (Large, Small, Codestral, Pixtral)
# Get your key at: https://console.mistral.ai/
# =============================================================================
MISTRAL_API_KEY=your-mistral-api-key-here

# =============================================================================
# xAI Grok Configuration (Grok 2, Grok 2 Mini, Vision)
# Get your key at: https://x.ai/api
# =============================================================================
XAI_API_KEY=your-xai-api-key-here

# =============================================================================
# Groq Configuration (Ultra-fast inference - Llama 3.3 70B, Mixtral)
# Get your key at: https://console.groq.com/keys
# =============================================================================
GROQ_API_KEY=gsk_your-key-here

# =============================================================================
# OpenRouter Configuration (Access 200+ models via single API!)
# Get your key at: https://openrouter.ai/keys
# =============================================================================
OPENROUTER_API_KEY=sk-or-your-key-here
# Optional: Your site URL and name for attribution
# OPENROUTER_SITE_URL=https://yoursite.com
# OPENROUTER_SITE_NAME=YourApp

# =============================================================================
# Ollama Configuration (FREE - Local models, complete privacy)
# Install Ollama: https://ollama.ai
# Then: ollama pull llama3.2
# No API key needed for Ollama!
# =============================================================================
OLLAMA_BASE_URL=http://localhost:11434

# =============================================================================
# Ember Configuration
# =============================================================================

# Configuration Path (optional)
# Default: ~/.config/ember/config.toml (Linux/macOS) or %APPDATA%\ember\config.toml (Windows)
EMBER_CONFIG=/path/to/custom/config.toml

# Log Level (optional, defaults to "warn")
# Options: trace, debug, info, warn, error
RUST_LOG=info

# =============================================================================
# Budget Configuration (Optional - set spending limits)
# =============================================================================
# Daily budget limit in USD
# EMBER_BUDGET_DAILY=10.00

# Hourly budget limit in USD
# EMBER_BUDGET_HOURLY=1.00

# Per-request budget limit in USD
# EMBER_BUDGET_PER_REQUEST=0.50

# Enforce budget limits (block requests that exceed)
# EMBER_BUDGET_ENFORCE=false

# Alert threshold (percentage, 0.0-1.0)
# EMBER_BUDGET_ALERT_THRESHOLD=0.8