# Ember Environment Variables Example
# Copy this file to .env and fill in your values
# DO NOT commit .env to version control!

# OpenAI API Key (required for OpenAI provider)
# Get your key at: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-your-key-here

# Anthropic API Key (required for Anthropic provider)
# Get your key at: https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-your-key-here

# Groq API Key (required for Groq provider - fast LLM inference)
# Get your key at: https://console.groq.com/keys
GROQ_API_KEY=gsk_your-key-here

# Ollama Base URL (optional, defaults to http://localhost:11434)
# Only needed if Ollama is running on a different host/port
OLLAMA_BASE_URL=http://localhost:11434

# Ember Configuration Path (optional)
# Default: ~/.config/ember/config.toml (Linux/macOS) or %APPDATA%\ember\config.toml (Windows)
EMBER_CONFIG=/path/to/custom/config.toml

# Log Level (optional, defaults to "warn")
# Options: trace, debug, info, warn, error
RUST_LOG=info