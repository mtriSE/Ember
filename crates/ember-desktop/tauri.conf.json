{
  "$schema": "https://schema.tauri.app/config/2.0.0",
  "productName": "Ember AI",
  "version": "0.1.0",
  "identifier": "dev.ember.desktop",
  "build": {
    "frontendDist": "../ember-web/static",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "cd ../ember-web/frontend && npm run dev",
    "beforeBuildCommand": "cd ../ember-web/frontend && npm run build"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "Ember AI",
        "label": "main",
        "width": 1200,
        "height": 800,
        "minWidth": 800,
        "minHeight": 600,
        "center": true,
        "resizable": true,
        "fullscreen": false,
        "decorations": true,
        "transparent": false,
        "visible": true,
        "focus": true
      }
    ],
    "trayIcon": {
      "iconPath": "icons/icon.png",
      "iconAsTemplate": true,
      "title": "Ember AI"
    },
    "security": {
      "csp": "default-src 'self'; script-src 'self' 'unsafe-inline'; style-src 'self' 'unsafe-inline'; img-src 'self' data: https:; connect-src 'self' http://localhost:* https://*.openai.com https://*.anthropic.com https://*.google.com"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": [],
    "shortDescription": "AI-powered coding assistant",
    "longDescription": "Ember AI is a powerful, privacy-first AI coding assistant that runs locally and supports multiple LLM providers.",
    "category": "DeveloperTool",
    "macOS": {
      "minimumSystemVersion": "10.15",
      "entitlements": null,
      "signingIdentity": null,
      "providerShortName": null
    },
    "windows": {
      "wix": null,
      "nsis": {
        "displayLanguageSelector": true,
        "installerIcon": "icons/icon.ico",
        "headerImage": "icons/nsis-header.bmp",
        "sidebarImage": "icons/nsis-sidebar.bmp"
      }
    },
    "linux": {
      "appimage": {
        "bundleMediaFramework": false
      },
      "deb": {
        "depends": ["libwebkit2gtk-4.1-0", "libgtk-3-0"],
        "section": "devel"
      },
      "rpm": {
        "release": "1"
      }
    },
    "publisher": "Ember AI",
    "copyright": "© 2024 Ember AI Contributors"
  },
  "plugins": {
    "shell": {
      "open": true
    },
    "global-shortcut": {
      "all": true
    },
    "updater": {
      "endpoints": [
        "https://github.com/ember-ai/ember/releases/latest/download/latest.json"
      ],
      "pubkey": ""
    },
    "notification": {
      "all": true
    },
    "autostart": {
      "macOS": {
        "appPath": "/Applications/Ember AI.app"
      }
    }
  }
}