{
  "name": "ember-ai",
  "displayName": "Ember AI",
  "description": "AI coding assistant powered by Ember",
  "version": "0.1.0",
  "publisher": "ember",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Programming Languages",
    "Machine Learning",
    "Other"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "ember.chat",
        "title": "Ember: Open Chat",
        "icon": "$(comment-discussion)"
      },
      {
        "command": "ember.explain",
        "title": "Ember: Explain Selection",
        "icon": "$(question)"
      },
      {
        "command": "ember.improve",
        "title": "Ember: Improve Selection",
        "icon": "$(sparkle)"
      },
      {
        "command": "ember.generateTests",
        "title": "Ember: Generate Tests",
        "icon": "$(beaker)"
      },
      {
        "command": "ember.fixCode",
        "title": "Ember: Fix Code",
        "icon": "$(wrench)"
      },
      {
        "command": "ember.addDocs",
        "title": "Ember: Add Documentation",
        "icon": "$(book)"
      },
      {
        "command": "ember.refactor",
        "title": "Ember: Refactor Selection",
        "icon": "$(edit)"
      }
    ],
    "configuration": {
      "title": "Ember AI",
      "properties": {
        "ember.serverUrl": {
          "type": "string",
          "default": "http://localhost:3000",
          "description": "URL of the Ember server"
        },
        "ember.model": {
          "type": "string",
          "default": "llama3.2",
          "description": "Default model to use"
        },
        "ember.autoStart": {
          "type": "boolean",
          "default": false,
          "description": "Automatically start Ember server"
        },
        "ember.inlineCompletions.enabled": {
          "type": "boolean",
          "default": true,
          "description": "Enable AI-powered inline code completions"
        },
        "ember.inlineCompletions.debounceMs": {
          "type": "number",
          "default": 500,
          "minimum": 100,
          "maximum": 2000,
          "description": "Delay in milliseconds before triggering inline completions"
        },
        "ember.inlineCompletions.maxTokens": {
          "type": "number",
          "default": 100,
          "minimum": 10,
          "maximum": 500,
          "description": "Maximum tokens for inline completions"
        },
        "ember.temperature": {
          "type": "number",
          "default": 0.7,
          "minimum": 0,
          "maximum": 2,
          "description": "Temperature for model responses (0 = precise, 2 = creative)"
        }
      }
    },
    "viewsContainers": {
      "activitybar": [
        {
          "id": "ember-sidebar",
          "title": "Ember AI",
          "icon": "resources/ember.svg"
        }
      ]
    },
    "views": {
      "ember-sidebar": [
        {
          "type": "webview",
          "id": "ember.chatView",
          "name": "Chat"
        }
      ]
    },
    "menus": {
      "editor/context": [
        {
          "submenu": "ember.submenu",
          "when": "editorHasSelection",
          "group": "ember"
        }
      ],
      "ember.submenu": [
        {
          "command": "ember.explain",
          "group": "1_understand"
        },
        {
          "command": "ember.improve",
          "group": "2_improve"
        },
        {
          "command": "ember.fixCode",
          "group": "2_improve"
        },
        {
          "command": "ember.refactor",
          "group": "2_improve"
        },
        {
          "command": "ember.addDocs",
          "group": "3_document"
        },
        {
          "command": "ember.generateTests",
          "group": "4_test"
        }
      ]
    },
    "submenus": [
      {
        "id": "ember.submenu",
        "label": "Ember AI"
      }
    ],
    "keybindings": [
      {
        "command": "ember.chat",
        "key": "ctrl+shift+e",
        "mac": "cmd+shift+e"
      },
      {
        "command": "ember.explain",
        "key": "ctrl+shift+/",
        "mac": "cmd+shift+/",
        "when": "editorHasSelection"
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "lint": "eslint src --ext ts",
    "package": "vsce package"
  },
  "devDependencies": {
    "@types/node": "^20.10.0",
    "@types/vscode": "^1.85.0",
    "@typescript-eslint/eslint-plugin": "^6.13.0",
    "@typescript-eslint/parser": "^6.13.0",
    "eslint": "^8.54.0",
    "typescript": "^5.3.2"
  },
  "dependencies": {
    "eventsource": "^2.0.2"
  }
}